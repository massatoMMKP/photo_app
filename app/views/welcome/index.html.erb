<%= render 'layouts/jumbotron' %>

<section class="features-section text-center">
  <div class="container">
    <h2 class="mb-5 font-weight-bold">Por que escolher nossa App?</h2>
    <div class="row">
      <div class="col-md-4 mb-4">
        <i class="fas fa-cloud-upload-alt feature-icon"></i>
        <h4>Upload Rápido</h4>
        <p class="text-muted">Faça backup de suas fotos em segundos com nossa tecnologia de compressão inteligente.</p>
      </div>
      <div class="col-md-4 mb-4">
        <i class="fas fa-magic feature-icon" style="color: #6f42c1;"></i>
        <h4>Edição Mágica</h4>
        <p class="text-muted">Ferramentas avançadas impulsionadas por IA para tornar cada foto uma obra de arte.</p>
      </div>
      <div class="col-md-4 mb-4">
        <i class="fas fa-share-alt feature-icon" style="color: #28a745;"></i>
        <h4>Compartilhamento Fácil</h4>
        <p class="text-muted">Crie galerias privadas ou compartilhe diretamente nas suas redes sociais favoritas.</p>
      </div>
    </div>
  </div>
</section>

<!-- Seção de Planos de Assinatura -->
<section id="planos" class="container my-5 py-5">
  <div class="text-center mb-5">
    <h2 class="font-weight-bold">Escolha seu Plano Ideal</h2>
    <p class="text-muted lead">Opções flexíveis para fotógrafos amadores e profissionais.</p>
  </div>

  <div class="row justify-content-center">
    
    <!-- Plano Premium -->
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="pricing-card">
        <div class="card-header">
          <h3>Premium Plan</h3>
          <div class="price">R$ 29<span class="price-span">/mês</span></div>
        </div>
        <div class="card-body d-flex flex-column">
          <ul class="mb-4 flex-grow-1">
            <li><i class="fas fa-check"></i> 100 GB de Armazenamento</li>
            <li><i class="fas fa-check"></i> Resolução Original (Sem perda)</li>
            <li><i class="fas fa-check"></i> Ferramentas de Edição Básicas</li>
            <li><i class="fas fa-check"></i> Compartilhamento por Link</li>
            <li><i class="fas fa-times text-muted" style="color: #ccc !important;"></i> Suporte Prioritário</li>
            <li><i class="fas fa-times text-muted" style="color: #ccc !important;"></i> IA Avançada</li>
          </ul>
          <div class="d-grid mt-auto">
           <%= button_to "Assinar Premium", payments_path, params: { plan: 'premium' }, method: :post, class: "btn btn-outline-primary-custom btn-custom", data: { turbo: false } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Plano Amaze (Destaque) -->
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="pricing-card card-amaze">
        <div class="popular-badge">Mais Popular</div>
        <div class="card-header">
          <h3>Amaze Plan</h3>
          <div class="price">R$ 59<span class="price-span">/mês</span></div>
        </div>
        <div class="card-body d-flex flex-column">
          <ul class="mb-4 flex-grow-1">
            <li><i class="fas fa-check"></i> <strong>Armazenamento Ilimitado</strong></li>
            <li><i class="fas fa-check"></i> Resolução Original e RAW</li>
            <li><i class="fas fa-check"></i> <strong>Todas as Ferramentas Pro</strong></li>
            <li><i class="fas fa-check"></i> Galerias com Senha</li>
            <li><i class="fas fa-check"></i> Suporte Prioritário 24/7</li>
            <li><i class="fas fa-check"></i> <strong>Filtros Mágicos IA</strong></li>
          </ul>
          <div class="d-grid mt-auto">
            <%= button_to "Seja Amaze", payments_path, params: { plan: 'amaze' }, method: :post, class: "btn btn-amaze btn-custom", data: { turbo: false } %>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<%= render 'layouts/footer' %>


